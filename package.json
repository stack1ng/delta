{
  "name": "@stack1ng/delta",
  "version": "0.1.2",
  "description": "Low-level, tree-shakable binary delta (GDelta) + compression (Zstd) with stream-first APIs and per-entry WASM binaries",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stack1ng/delta.git"
  },
  "homepage": "https://github.com/stack1ng/delta#readme",
  "bugs": {
    "url": "https://github.com/stack1ng/delta/issues"
  },
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "imports": {
    "#wasm/*": {
      "convex": "./wasm/*.js",
      "default": "./dist/internal/wasm.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./gdelta/encode": {
      "types": "./dist/gdelta/encode.d.ts",
      "default": "./dist/gdelta/encode.js"
    },
    "./gdelta/decode": {
      "types": "./dist/gdelta/decode.d.ts",
      "default": "./dist/gdelta/decode.js"
    },
    "./zstd/compress": {
      "types": "./dist/zstd/compress.d.ts",
      "default": "./dist/zstd/compress.js"
    },
    "./zstd/decompress": {
      "types": "./dist/zstd/decompress.d.ts",
      "default": "./dist/zstd/decompress.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "default": "./dist/pipeline/index.js"
    },
    "./pipeline/encode": {
      "types": "./dist/pipeline/encode.d.ts",
      "default": "./dist/pipeline/encode.js"
    },
    "./pipeline/decode": {
      "types": "./dist/pipeline/decode.d.ts",
      "default": "./dist/pipeline/decode.js"
    },
    "./wasm/*.wasm": "./wasm/*.wasm"
  },
  "files": [
    "dist",
    "wasm",
    "README.md",
    "FRAME.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "NOTICE",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun run build:wasm && bun run build:ts",
    "build:wasm": "./scripts/build-wasm.sh",
    "build:ts": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && oxlint && bun run lint:rust",
    "lint:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings",
    "lint:fix": "biome check --write . && oxlint --fix && cargo fmt --all",
    "test": "vitest run",
    "test:rust": "cargo test --workspace",
    "bench": "node scripts/bench.ts",
    "prepack": "node scripts/check-artifacts.mjs",
    "preversion": "bun install --frozen-lockfile && bun run ci",
    "version": "node scripts/changelog.mjs && git add CHANGELOG.md",
    "release": "node scripts/release.mjs",
    "alpha": "npm version prerelease --preid alpha && git push --follow-tags",
    "ci": "bun run build && bun run typecheck && bun run lint && bun run test:rust && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "esbuild": "0.27.0",
    "oxlint": "^1.73.0",
    "rolldown": "^1.1.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
